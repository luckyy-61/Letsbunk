  <div class="nav-item" id="nav-post" onclick="showScreen('post')">
    <span class="nav-icon">✈️</span>Post Trip
  </div>
  <div class="nav-item" id="nav-chat" onclick="showScreen('chat')">
    <span class="nav-icon">💬</span>Squad Chat
  </div>
  <div class="nav-item" id="nav-profile" onclick="showScreen('profile')">
    <span class="nav-icon">👤</span>Profile
  </div>
</nav>

<!-- ═══════════ TRIP DETAIL MODAL ═══════════ -->
<div class="modal-overlay" id="trip-modal" onclick="closeModal('trip-modal')">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-handle"></div>
    <div class="modal-title" id="modal-dest-title">Destination</div>
    <div id="modal-body"></div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ── SCREENS ──
const SCREENS_WITH_NAV = ['home','explore','post','quiz','profile','chat'];
const NAV_MAP = { home:'nav-home', explore:'nav-explore', post:'nav-post', chat:'nav-chat', profile:'nav-profile' };

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const nav = document.getElementById('app-nav');
  if (SCREENS_WITH_NAV.includes(id)) {
    nav.style.display = 'flex';
  } else {
    nav.style.display = 'none';
  }
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (NAV_MAP[id]) document.getElementById(NAV_MAP[id]).classList.add('active');
  window.scrollTo(0,0);
}

function goHome() {
  showScreen('home');
  document.getElementById('app-nav').style.display = 'flex';
}

// ── TOAST ──
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}

// ── JOIN TRIP ──
function joinTrip(btnId, cardId, name) {
  const btn = document.getElementById(btnId);
  if (btn.classList.contains('joined')) return;
  btn.classList.add('joined');
  btn.innerHTML = '✅ Joined!';
  showToast(`✅ You're in! Added to ${name} squad chat 💬`);
  setTimeout(() => {
    if (confirm(`Squad formed! Open ${name} group chat?`)) showScreen('chat');
  }, 800);
}

// ── FILTER TAGS ──
function filterTag(el, type) {
  el.parentNode.querySelectorAll('.tag').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  showToast(`Filtered: ${el.textContent}`);
}

// ── SEARCH ──
function searchTrips(val) {
  if (val.length > 2) showToast(`Searching "${val}"… 🔍`);
}

// ── TOGGLE VIBE ──
function toggleVibe(el) {
  el.classList.toggle('selected');
}

// ── POST TRIP ──
function postTrip() {
  const dest = document.getElementById('dest-input').value;
  const desc = document.getElementById('trip-desc').value;
  if (!dest && !desc) { showToast('Please fill in your destination! 📍'); return; }
  showToast('🎉 Trip posted to feed! Squad matching started…');
  setTimeout(() => {
    document.getElementById('dest-input').value = '';
    document.getElementById('trip-desc').value = '';
    document.getElementById('budget-pp').value = '';
    document.getElementById('squad-size').value = '';
    showScreen('home');
  }, 1500);
}

// ── VERIFY PHONE ──
function verifyPhone() {
  const otp = prompt('Enter OTP sent to your phone (demo: any 4 digits)');
  if (otp && otp.length >= 4) {
    document.getElementById('phone-verify').textContent = '✅';
    showToast('📱 Phone verified! Full access unlocked 🎉');
  }
}

// ── TRIP DETAIL MODAL ──
function showTripDetail(name, emoji, price) {
  document.getElementById('modal-dest-title').textContent = emoji + ' ' + name;
  document.getElementById('modal-body').innerHTML = `
    <div style="color:var(--muted);font-size:13px;margin-bottom:16px">Popular student destination · Bunk Mentor available</div>
    <div class="stat-row" style="margin-bottom:16px">
      <div class="stat-chip"><div class="val">${price}</div><div class="lbl">From (pp)</div></div>
      <div class="stat-chip"><div class="val">4.8⭐</div><div class="lbl">Avg Rating</div></div>
    </div>
    <div style="margin-bottom:16px;font-size:13px;line-height:1.7;color:var(--muted)">
      ${name} is one of the most popular student destinations on Let's Bunk. Budget hostels, student discounts, and verified Bunk Mentors available year-round.
    </div>
    <div style="display:flex;gap:10px">
      <button class="btn btn-primary" style="flex:1" onclick="closeModal('trip-modal');showScreen('post');showToast('Creating trip to ${name}! 📝')">Plan a Trip</button>
      <button class="btn btn-outline" style="flex:1" onclick="closeModal('trip-modal');showScreen('home');showToast('Showing ${name} open trips 🔍')">Open Trips</button>
    </div>
  `;
  document.getElementById('trip-modal').classList.add('open');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

// ── QUIZ ──
const questions = [
  { q: "What's your daily travel pace?", opts: [["🌅","Sunrise trekker"],["☀️","Midday explorer"],["🌙","Night owl traveler"],["🎲","Spontaneous chaos"]] },
  { q: "What's your ideal trip budget per day?", opts: [["💰","Under ₹500"],["💸","₹500–1,000"],["💳","₹1,000–2,000"],["🤑","Money no object"]] },
  { q: "Your ideal travel companion count?", opts: [["👤","Just me + 1"],["👥","Small squad (3–5)"],["🎊","Big group (6+)"],["🎲","Whatever forms"]] },
  { q: "What do you care most about?", opts: [["🛡️","Safety & verification"],["💸","Budget & deals"],["🎵","Vibe & energy match"],["🗺️","Unique experiences"]] },
  { q: "Best type of trip?", opts: [["🏔️","Mountains & trekking"],["🏖️","Beaches & chill"],["🏯","Heritage & culture"],["🍜","Food & street culture"]] },
  { q: "How far in advance do you plan?", opts: [["📅","Weeks ahead"],["📆","A few days before"],["📲","Day before"],["⚡","Same day only"]] },
  { q: "What matters most in a travel squad?", opts: [["🤝","Same energy & vibe"],["💰","Same budget level"],["🆔","Verified identity"],["😎","All of the above"]] }
];

const vibeTypes = [
  "Sunrise Adventurer 🌅","Budget Explorer 🎒","Chill Wanderer 🏖️","Chaos Traveller ⚡",
  "Heritage Hunter 🏯","Food Trail Blazer 🍜","Mountain Soul 🏔️","Night Owl Nomad 🌙"
];

let quizAnswers = {};
let currentQ = 0;

function renderQuiz() {
  const q = questions[currentQ];
  const pct = Math.round(((currentQ + 1) / questions.length) * 100);
  document.getElementById('quiz-bar').style.width = pct + '%';
  document.getElementById('quiz-counter').textContent = `Q${currentQ + 1} / ${questions.length}`;

  let html = `<div class="quiz-q">${q.q}</div><div class="quiz-options">`;
  q.opts.forEach((o, i) => {
    const sel = quizAnswers[currentQ] === i ? ' selected' : '';
    html += `<div class="quiz-opt${sel}" onclick="selectOpt(${i}, this)">
      <span class="opt-ico">${o[0]}</span><span>${o[1]}</span>
    </div>`;
  });
  html += '</div>';
  document.getElementById('quiz-content').innerHTML = html;
  document.getElementById('quiz-back').style.display = currentQ > 0 ? 'inline-flex' : 'none';
  document.getElementById('quiz-next').textContent = currentQ === questions.length - 1 ? 'See My Vibe! 🎉' : 'Next →';
}

function selectOpt(i, el) {
  quizAnswers[currentQ] = i;
  el.parentNode.querySelectorAll('.quiz-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}

function quizNext() {
  if (quizAnswers[currentQ] === undefined) { showToast('Pick an option first! 👆'); return; }
  if (currentQ < questions.length - 1) {
    currentQ++;
    renderQuiz();
  } else {
    // Show result
    const vibe = vibeTypes[quizAnswers[0] ?? 0];
    document.getElementById('vibe-type').textContent = vibe;
    document.getElementById('quiz-body').style.display = 'none';
    document.getElementById('quiz-result').style.display = 'block';
  }
}

function quizBack() {
  if (currentQ > 0) { currentQ--; renderQuiz(); }
}

// Init quiz when screen opens
document.getElementById('nav-quiz-dummy') || (() => {
  document.querySelectorAll('.nav-item').forEach(n => {
    n.addEventListener('click', () => {
      if (n.id === 'nav-quiz') { currentQ = 0; quizAnswers = {}; renderQuiz(); document.getElementById('quiz-body').style.display='block'; document.getElementById('quiz-result').style.display='none'; }
    });
  });
})();

// Patch showScreen to init quiz
const _orig = showScreen;
window.showScreen = function(id) {
  _orig(id);
  if (id === 'quiz') {
    currentQ = 0; quizAnswers = {};
    document.getElementById('quiz-body').style.display = 'block';
    document.getElementById('quiz-result').style.display = 'none';
    renderQuiz();
  }
};

// ── CHAT ──
function sendMsg() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text) return;
  const area = document.getElementById('chat-area');
  const now = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  const msgEl = document.createElement('div');
  msgEl.className = 'msg me';
  msgEl.innerHTML = `<div class="msg-bubble">${text}</div><div class="msg-time">${now}</div>`;
  area.appendChild(msgEl);
  input.value = '';
  area.scrollTop = area.scrollHeight;

  // Auto-reply
  const replies = [
    "Sounds great! 🙌","Count me in 👍","When are we leaving exactly?","I'll check my timetable 📅","Budget looks good to me 💸","Let's go!! 🎉"];
  setTimeout(() => {
    const names = ["Arjun M.","Neha R.","Karan S.","Rahul (Mentor) 🧭"];
    const r = document.createElement('div');
    r.className = 'msg them';
    r.innerHTML = `<div class="msg-sender">${names[Math.floor(Math.random()*names.length)]}</div>
      <div class="msg-bubble">${replies[Math.floor(Math.random()*replies.length)]}</div>
      <div class="msg-time">${now}</div>`;
    area.appendChild(r);
    area.scrollTop = area.scrollHeight;
  }, 900 + Math.random()*600);
}

// Init
document.getElementById('app-nav').style.display = 'none';
renderQuiz();
</script>
</body>
</html>
